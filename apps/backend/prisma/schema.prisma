// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Roles {
  admin
  user
}

model User {
  id          String    @id @default(uuid())
  firebaseUid String    @unique @map("firebase_uid")
  name        String
  email       String    @unique
  role        Roles     @default(user)
  photoURL    String?   @map("photo_url")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  lessonPlans LessonPlan[]
  Example     Example[]
  Rating      Rating[]

  @@map("users")
}

model Approach {
  id    String @id @default(uuid())
  title String

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  axis        Axis[]
  lessonPlans LessonPlan[]

  @@map("approaches")
}

model Axis {
  id    String @id @default(uuid())
  title String

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  approachesId String   @map("approaches_id")
  approache    Approach @relation(fields: [approachesId], references: [id], onDelete: Cascade)

  question       Question[]
  lessonPlanAxes LessonPlanAxis[]

  @@map("axis")
}

model Question {
  id        String    @id @default(uuid())
  title     String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  axisId String @map("axis_id")
  axis   Axis   @relation(fields: [axisId], references: [id], onDelete: Cascade)

  transitionsFromHere Transition[]       @relation("FromQuestion")
  transitionToHere    Transition?        @relation("ToQuestion")
  lessonPlanAnswers   LessonPlanAnswer[]

  @@map("questions")
}

model Transition {
  id             String  @id @default(uuid())
  fromQuestionId String  @map("from_question_id")
  answerId       String  @map("answer_id")
  toQuestionId   String? @unique @map("to_question_id")

  fromQuestion Question  @relation("FromQuestion", fields: [fromQuestionId], references: [id], onDelete: Cascade)
  toQuestion   Question? @relation("ToQuestion", fields: [toQuestionId], references: [id], onDelete: Cascade)
  answerValue  Answer    @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@unique([fromQuestionId, answerId])
  @@map("transitions")
}

model Answer {
  id                String             @id @default(uuid())
  title             String
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime?          @updatedAt @map("updated_at")
  steps             Step[]
  transition        Transition[]
  lessonPlanAnswers LessonPlanAnswer[]

  @@map("answers")
}

model Step {
  id          String    @id @default(uuid())
  title       String
  description String
  order       Int
  answerId    String
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  answer Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@map("steps")
}

enum Complexity {
  beginner
  intermediate
}

enum ExampleType {
  correct
  erroneous
  both
}

enum ModatilyType {
  inPerson
  hybrid
  remote
}

model LessonPlan {
  id             String       @id @default(uuid())
  title          String
  description    String?
  subjectId      String       @map("subject_id")
  topicId        String?      @map("topic_id")
  complexity     Complexity?
  example        ExampleType?
  year           String
  workload       String
  modality       ModatilyType
  contents       String[]
  materials      String[]
  priorKnowledge String?      @map("prior_knowledge")

  isPublic   Boolean   @default(true) @map("is_public")
  userId     String    @map("user_id")
  approachId String    @map("approach_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  approach Approach         @relation(fields: [approachId], references: [id], onDelete: Cascade)
  subject  Subject?         @relation(fields: [subjectId], references: [id])
  topic    Topic?           @relation(fields: [topicId], references: [id])
  axes     LessonPlanAxis[]
  Rating   Rating[]

  @@map("lesson_plans")
}

model LessonPlanAxis {
  id           String             @id @default(uuid())
  lessonPlanId String             @map("lesson_plan_id")
  axisId       String             @map("axis_id")
  answers      LessonPlanAnswer[]
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime?          @updatedAt @map("updated_at")

  lessonPlan LessonPlan @relation(fields: [lessonPlanId], references: [id], onDelete: Cascade)
  axis       Axis       @relation(fields: [axisId], references: [id], onDelete: Cascade)

  @@unique([lessonPlanId, axisId])
  @@map("lesson_plan_axes")
}

model LessonPlanAnswer {
  id               String           @id @default(uuid())
  lessonPlanAxisId String           @map("lesson_plan_axis_id")
  questionId       String           @map("question_id")
  answerId         String           @map("answer_id")
  steps            LessonPlanStep[]
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime?        @updatedAt @map("updated_at")

  lessonPlanAxis LessonPlanAxis @relation(fields: [lessonPlanAxisId], references: [id], onDelete: Cascade)
  question       Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer         Answer         @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@unique([lessonPlanAxisId, questionId])
  @@map("lesson_plan_answers")
}

model LessonPlanStep {
  id                 String    @id @default(uuid())
  lessonPlanAnswerId String    @map("lesson_plan_answer_id")
  title              String
  description        String
  order              Int
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime? @updatedAt @map("updated_at")

  lessonPlanAnswer LessonPlanAnswer @relation(fields: [lessonPlanAnswerId], references: [id], onDelete: Cascade)

  @@map("lesson_plan_steps")
}

model Subject {
  id         String       @id @default(uuid())
  title      String
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime?    @updatedAt @map("updated_at")
  lessonPlan LessonPlan[]

  @@map("subjects")
}

model Topic {
  id         String       @id @default(uuid())
  title      String
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime?    @updatedAt @map("updated_at")
  lessonPlan LessonPlan[]
  example    Example[]

  @@map("topics")
}

model Example {
  id           String         @id @default(uuid())
  title        String
  description  String
  references   String[]
  topicId      String         @map("topic_id")
  authorId     String         @map("author_id")
  isApprove    Boolean        @map("is_approve")
  exampleModel ExampleModel[]
  type         ExampleType
  attachment   Attachment[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  topic  Topic    @relation(fields: [topicId], references: [id])
  author User     @relation(fields: [authorId], references: [id])
  Rating Rating[]

  @@map("examples")
}

model Model {
  id           String         @id @default(uuid())
  title        String
  exampleModel ExampleModel[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@map("models")
}

model ExampleModel {
  exampleId String @map("example_id")
  modelId   String @map("model_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  example Example @relation(fields: [exampleId], references: [id])
  model   Model   @relation(fields: [modelId], references: [id])

  @@id([exampleId, modelId])
  @@map("example_models")
}

model Rating {
  id           String  @id @default(uuid())
  comment      String?
  rate         Int
  lessonPlanId String? @map("lesson_plan_id")
  exampleId    String? @map("example_id")
  userId       String  @map("user_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  example    Example?    @relation(fields: [exampleId], references: [id])
  lessonPlan LessonPlan? @relation(fields: [lessonPlanId], references: [id])
  user       User        @relation(fields: [userId], references: [id])

  @@unique([userId, exampleId])
  @@unique([userId, lessonPlanId])
  @@map("ratings")
}

model Attachment {
  id        String  @id @default(cuid())
  title     String
  type      String
  url       String
  key       String  @unique
  size      Int?
  exampleId String? @map("example_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  Example Example? @relation(fields: [exampleId], references: [id])

  @@map("attachments")
}
